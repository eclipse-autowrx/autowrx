NAME=autowrx
FRONTEND_PORT=3201
JWT_SECRET=a-secret-password
CORS_ORIGINS=localhost:\d+,127\.0\.0\.1:\d+,digital\.auto,.*\.digital\.auto,.*\.digitalauto\.tech
ADMIN_EMAILS=admin@email.com
ADMIN_PASSWORD=admin123

# ── Backup & Restore ─────────────────────────────────────────────────────────
# Host directory where backup ZIPs are stored (mounted to /usr/src/playground-be/backups inside container)
# BACKUP_PATH_HOST=./data/backups

# Auto-restore on startup: set to the container-side path of the backup ZIP.
# Place the file in BACKUP_PATH_HOST on the host first, then reference it here.
# Example: RESTORE_FILE=/usr/src/playground-be/backups/restore.zip
# After a successful restore the file is renamed to *.restored — remove it or
# clear this variable before restarting to avoid running again.
# RESTORE_FILE=

# Set to 1 to replace conflicting items during auto-restore (default: skip).
# RESTORE_REPLACE_ALL=
