# Dependencies — reinstalled inside Docker
node_modules
frontend/node_modules
backend/node_modules

# Build artifacts
frontend/dist
backend/static/frontend-dist

# Dev / test files
*.log
.git
.github
*.md
!build-frontend.sh

# Editor / OS
.DS_Store
*.swp
.vscode
.idea

# Local proxy config — Docker uses proxy from daemon.json (HTTP_PROXY build args)
# .npmrc files hardcode 127.0.0.1:3128 which doesn't work inside containers
.npmrc
**/.npmrc

# Local env files (secrets should come from docker-compose env vars)
.env
backend/.env
frontend/.env

# Test files
backend/test-*.js
